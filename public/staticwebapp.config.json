{
  "routes": [
    {
      "route": "/auth",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/demo",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/demo/*",
      "allowedRoles": ["anonymous"]
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.jpg",
      "/*.jpeg",
      "/*.gif",
      "/*.svg",
      "/*.ico",
      "/*.json",
      "/*.map"
    ]
  }
}
